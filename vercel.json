{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/api/proxy", "dest": "/api/proxy.js" },
    { "src": "/api/research", "dest": "/api/research.js" },
    { "src": "/api/parse-document", "dest": "/api/parse-document.js" },
    { "src": "/api/generate-sheet", "dest": "/api/generate-sheet.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
